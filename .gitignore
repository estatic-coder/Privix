# =============================================================
# Privix — .gitignore
# Stack: Node.js / Express · React / Vite · Python venv
# =============================================================

# ── Dependencies ──────────────────────────────────────────────
node_modules/
.npm
.yarn/
.pnp
.pnp.js

# ── Build Outputs ─────────────────────────────────────────────
dist/
build/
out/
.vite/
*.tsbuildinfo

# ── Python Virtual Environment ────────────────────────────────
venv/
.venv/
env/
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
*.egg
.eggs/
.Python
pip-log.txt
pip-delete-this-directory.txt

# ── Environment Variables ─────────────────────────────────────
# Never commit credentials or secrets
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.*.local
*.secret
secrets.json

# ── Logs ──────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Runtime / OS Cache ────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Editor & IDE ──────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.bak
*.orig

# ── TypeScript ────────────────────────────────────────────────
*.js.map
*.d.ts.map

# ── Testing ───────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov

# ── Package Managers ──────────────────────────────────────────
.pnpm-store/
.yarn-integrity

# ── Misc ──────────────────────────────────────────────────────
.cache/
.parcel-cache/
.turbo/
.vercel/
.netlify/
*.local
tmp/
temp/
